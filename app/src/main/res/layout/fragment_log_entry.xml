<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/solar_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Log Today's Energy"
            android:textColor="@color/solar_yellow"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <!-- Weather Selector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Weather"
            android:textColor="@color/solar_grey"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_weather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rb_sunny"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="☀️"
                android:textColor="@color/solar_white"
                android:buttonTint="@color/solar_yellow" />

            <RadioButton
                android:id="@+id/rb_partly"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⛅"
                android:textColor="@color/solar_white"
                android:buttonTint="@color/solar_yellow" />

            <RadioButton
                android:id="@+id/rb_cloudy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="☁️"
                android:textColor="@color/solar_white"
                android:buttonTint="@color/solar_yellow" />

            <RadioButton
                android:id="@+id/rb_rainy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌧️"
                android:textColor="@color/solar_white"
                android:buttonTint="@color/solar_yellow" />
        </RadioGroup>

        <!-- Simulate Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_simulate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Simulate Generation"
            android:textColor="@color/solar_black"
            app:backgroundTint="@color/solar_yellow"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_simulated_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/solar_green"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Generation Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Solar Generated (kWh)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/solar_yellow"
            app:hintTextColor="@color/solar_yellow"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_generated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/solar_white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Consumption Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Home Consumed (kWh)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/solar_orange"
            app:hintTextColor="@color/solar_orange"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_consumed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/solar_white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Battery Level -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔋 Battery Level"
            android:textColor="@color/solar_grey"
            android:textSize="13sp"
            android:paddingBottom="4dp" />

        <SeekBar
            android:id="@+id/seekbar_battery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/solar_yellow"
            android:thumbTint="@color/solar_yellow"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_battery_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@color/solar_yellow"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Rate per Unit -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Rate per Unit (₹/kWh)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/solar_green"
            app:hintTextColor="@color/solar_green"
            android:layout_marginBottom="20dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="8.0"
                android:textColor="@color/solar_white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="💾 SAVE TODAY'S LOG"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/solar_black"
            app:backgroundTint="@color/solar_yellow"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>