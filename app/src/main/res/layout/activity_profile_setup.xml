<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/solar_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Setup Your Profile"
            android:textColor="@color/solar_yellow"
            android:textSize="26sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tell us about your solar setup"
            android:textColor="@color/solar_grey"
            android:textSize="13sp"
            android:paddingBottom="24dp" />

        <!-- Profile Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/solar_card_bg"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Personal Info"
                    android:textColor="@color/solar_yellow"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingBottom="12dp" />

                <!-- Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Full Name"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="@color/solar_white"
                    app:boxStrokeColor="@color/solar_yellow"
                    app:hintTextColor="@color/solar_yellow">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_setup_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textCursorDrawable="@null"
                        android:inputType="textPersonName" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Location -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="City / Village"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="@color/solar_white"
                    app:boxStrokeColor="@color/solar_yellow"
                    app:hintTextColor="@color/solar_yellow">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_setup_location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textCursorDrawable="@null" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Solar Setup Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/solar_card_bg"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Solar Setup"
                    android:textColor="@color/solar_yellow"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingBottom="12dp" />

                <!-- Capacity -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Panel Capacity (kW)"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="@color/solar_white"
                    app:boxStrokeColor="@color/solar_yellow"
                    app:hintTextColor="@color/solar_yellow">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_setup_capacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2.0"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textCursorDrawable="@null"
                        android:inputType="numberDecimal" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Rate -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Electricity Rate (₹/kWh)"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="@color/solar_white"
                    app:boxStrokeColor="@color/solar_green"
                    app:hintTextColor="@color/solar_green">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_setup_rate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="8.0"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textCursorDrawable="@null"
                        android:inputType="numberDecimal" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Create Password (min 6 characters)"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxBackgroundColor="@color/solar_white"
                    app:boxStrokeColor="@color/solar_orange"
                    app:hintTextColor="@color/solar_orange"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_setup_pin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textCursorDrawable="@null"
                        android:inputType="textPassword" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Start Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🚀 START MY SOLAR JOURNEY"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/solar_black"
            app:backgroundTint="@color/solar_yellow"
            app:cornerRadius="12dp" />

    </LinearLayout>

</ScrollView>